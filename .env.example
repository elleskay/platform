# Platform-level env vars only. App-specific keys live in each app's own .env.example.

# AWS (for CDK deploy)
AWS_REGION=ap-southeast-1
AWS_ACCOUNT_ID=

# CI / GitHub
GITHUB_TOKEN=

# --- App runtime env vars (set per app) ---
# All five helpers no-op cleanly when their env vars aren't set. Set them in
# GitHub Actions secrets/variables for production. Local dev is fine without.

# Auth.js
AUTH_SECRET=
AUTH_URL=

# Database (the app picks the provider; Neon serverless Postgres is the default)
DATABASE_URL=

# Sentry (wire pattern in apps/_template, gracefully no-ops without DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# PostHog (wire pattern in apps/_template, gracefully no-ops without key)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Resend (lib/email.ts helper; no-ops without key)
RESEND_API_KEY=

# Upstash Redis (lib/rate-limit.ts helper; no-ops without keys)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Server Actions allowed origins (build-time)
ALLOWED_ORIGINS=
